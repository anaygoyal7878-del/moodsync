{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm ci && npm run build"
  },
  "deploy": {
    "startCommand": "node workers/dist/spotifyPlaybackCheckWorker.js",
    "cronSchedule": "*/5 * * * *",
    "restartPolicyType": "NEVER"
  }
}
