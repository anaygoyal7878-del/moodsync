// MoodSync data model.
//
// Scale notes: `biometric_readings` is the table that grows unbounded with
// user count and wearable sync frequency. In production this is a strong
// candidate for time-based partitioning (e.g. pg_partman by month) and a
// retention/rollup policy that ages raw readings out into `insights` after
// N days — that's an operational migration, not a Prisma schema change, so
// it isn't modeled here, but `@@index([userId, timestamp])` is chosen with
// that partitioning key in mind.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  displayName  String?
  timezone     String   @default("UTC")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens        RefreshToken[]
  wearableConnections  WearableConnection[]
  smartHomeConnections SmartHomeConnection[]
  automationRules      AutomationRule[]
  biometricReadings    BiometricReading[]
  insights             Insight[]
  recommendations      Recommendation[]
  automationLogs       AutomationExecutionLog[]
  notifications        Notification[]
  preferences          UserPreferences?

  @@map("users")
}

/// Our own session refresh tokens (JWT auth), unrelated to third-party
/// OAuth tokens below. Only a hash is ever stored — the raw token exists
/// only in the client's possession.
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  userAgent String?
  ipAddress String?
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

enum WearableProvider {
  WHOOP
  GOOGLE_HEALTH
  GARMIN
  APPLE_HEALTH
  AMAZFIT
}

enum SmartHomeProvider {
  HUE
  SPOTIFY
  ECOBEE
  ALEXA
}

enum ConnectionStatus {
  ACTIVE
  EXPIRED
  REVOKED
  ERROR
  NOT_YET_AVAILABLE
}

/// Third-party OAuth credentials. Access/refresh tokens are AES-256-GCM
/// encrypted at the application layer (backend/src/lib/crypto.ts) before
/// insert — this table only ever holds ciphertext + nonce, never plaintext.
/// One row belongs to exactly one connection (wearable XOR smart home),
/// enforced by the unique FK on each connection table rather than a
/// polymorphic reverse relation.
model OAuthToken {
  id                       String   @id @default(uuid())
  accessTokenCiphertext    Bytes
  accessTokenNonce         Bytes
  refreshTokenCiphertext   Bytes?
  refreshTokenNonce        Bytes?
  /// Generic slot for a third encrypted secret some providers issue
  /// alongside the OAuth pair — e.g. Philips Hue's long-lived
  /// `hue-application-key`, which functions as a credential and gets the
  /// same encryption-at-rest treatment as the access/refresh tokens
  /// rather than living in a connection's plaintext `metadata` JSON.
  providerSecretCiphertext Bytes?
  providerSecretNonce      Bytes?
  scope                    String
  expiresAt                DateTime
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  wearableConnection  WearableConnection?
  smartHomeConnection SmartHomeConnection?

  @@map("oauth_tokens")
}

model WearableConnection {
  id             String           @id @default(uuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       WearableProvider
  providerUserId String?
  status         ConnectionStatus @default(ACTIVE)
  oauthTokenId   String?          @unique
  oauthToken     OAuthToken?      @relation(fields: [oauthTokenId], references: [id], onDelete: SetNull)
  lastSyncedAt   DateTime?
  /// Device name/battery fields are nullable because only some providers'
  /// APIs expose them — confirmed present for Google Health (Fitbit) via
  /// `users.pairedDevices` (batteryLevel/batteryStatus/deviceVersion);
  /// confirmed ABSENT from WHOOP's public API (no battery endpoint exists
  /// in their documented resource categories). See
  /// docs/INTEGRATIONS_RESEARCH.md.
  deviceName     String?
  /// 0-100, or null if the provider doesn't expose it.
  batteryLevel   Int?
  /// Provider's own battery status string (e.g. Fitbit's High/Medium/Low/Empty),
  /// kept as free text rather than an enum since it's provider-specific.
  batteryStatus  String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([userId, provider])
  @@index([provider, status])
  @@map("wearable_connections")
}

model SmartHomeConnection {
  id                String            @id @default(uuid())
  userId            String
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          SmartHomeProvider
  providerAccountId String?
  status            ConnectionStatus  @default(ACTIVE)
  oauthTokenId      String?           @unique
  oauthToken        OAuthToken?       @relation(fields: [oauthTokenId], references: [id], onDelete: SetNull)
  /// Provider-specific non-secret metadata, e.g. { "bridgeId": "..." } for
  /// Hue or { "activeDeviceId": "..." } for Spotify.
  metadata          Json              @default("{}")
  lastSyncedAt      DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  connectedDevices ConnectedDevice[]

  @@unique([userId, provider])
  @@index([provider, status])
  @@map("smart_home_connections")
}

model ConnectedDevice {
  id                    String              @id @default(uuid())
  smartHomeConnectionId String
  smartHomeConnection   SmartHomeConnection @relation(fields: [smartHomeConnectionId], references: [id], onDelete: Cascade)
  externalDeviceId      String
  name                  String
  deviceType            String
  room                  String?
  isOnline              Boolean             @default(true)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@unique([smartHomeConnectionId, externalDeviceId])
  @@map("connected_devices")
}

/// One row per normalized reading per provider sync. See
/// shared/src/wearables.ts for the field-availability-by-provider notes —
/// every metric field here is nullable because no provider fills all of
/// them.
model BiometricReading {
  id                   String           @id @default(uuid())
  userId               String
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider             WearableProvider
  timestamp            DateTime
  heartRate            Float?
  restingHeartRate     Float?
  /// Milliseconds (SDNN). Apple Health-only today.
  heartRateVariability Float?
  /// Breaths per minute. Apple Health-only today.
  respiratoryRate      Float?
  /// 0-100 percentage (SpO2). Apple Health-only today.
  bloodOxygen          Float?
  sleepScore           Float?
  recoveryScore        Float?
  stressLevel          Float?
  activityLevel        Float?
  steps                Int?
  calories             Float?
  createdAt            DateTime         @default(now())

  // Frequent-polling providers (e.g. Fitbit heart-rate samples on a
  // 5-minute worker cadence) can re-fetch a data point already inserted
  // by a previous run when its lookback window overlaps — this constraint
  // lets bulkInsert use skipDuplicates instead of accumulating repeats.
  @@unique([userId, provider, timestamp])
  @@index([userId, timestamp])
  @@map("biometric_readings")
}

model AutomationRule {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  enabled         Boolean  @default(true)
  /// RuleCondition[] from shared/src/automation.ts, ANDed together
  conditions      Json
  /// AutomationAction[] from shared/src/automation.ts
  actions         Json
  cooldownMinutes Int      @default(30)
  /// 0-100, default 50 — resolves conflicts when two matched rules target
  /// the same resource in one dispatch pass (see ai/src/dispatch.ts's
  /// `resourceKeyFor`). Rules that never collide with another are
  /// unaffected by this value.
  priority        Int      @default(50)
  /// TimeWindow ({start, end} "HH:mm") from shared/src/automation.ts, or
  /// null for a purely biometric-triggered rule. Schedule-triggered
  /// templates (Focus Mode, Sleep Preparation) rely on this alongside an
  /// empty `conditions` array — see docs/DECISION_ENGINE_ARCHITECTURE.md.
  timeWindow      Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  executionLogs AutomationExecutionLog[]

  @@index([userId, enabled])
  @@map("automation_rules")
}

enum ExecutionOutcome {
  EXECUTED
  SKIPPED_COOLDOWN
  SKIPPED_DISABLED
  /// Lost a same-resource conflict to a higher-priority rule matched in
  /// the same dispatch pass — see ai/src/dispatch.ts.
  SKIPPED_CONFLICT
  /// The user had automations paused (UserPreferences.automationsPausedUntil)
  /// at dispatch time.
  SKIPPED_MANUAL_PAUSE
  /// Hit the per-user hourly action-execution rate limit — a safety check,
  /// not a user preference (see ai/src/dispatch.ts's RATE_LIMIT constant).
  SKIPPED_SAFETY_RATE_LIMIT
  FAILED
}

model AutomationExecutionLog {
  id               String           @id @default(uuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  ruleId           String
  rule             AutomationRule   @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  triggerReadingId String?
  outcome          ExecutionOutcome
  failureReason    String?
  /// Human-readable explainability text (ai/src/explain.ts) — why this
  /// outcome happened, in terms of the actual reading values / conflict /
  /// pause / rate limit involved. Null for rows logged before this field
  /// existed.
  reason           String?
  executedAt       DateTime         @default(now())

  @@index([userId, executedAt])
  @@index([ruleId, executedAt])
  @@map("automation_execution_logs")
}

/// A real, persisted, explainable notification — the notification engine
/// described in docs/DECISION_ENGINE_ARCHITECTURE.md. Generated
/// automatically for every dispatch outcome (not just a dedicated
/// notification action type), reusing the same `reason` text stored on
/// `AutomationExecutionLog`.
model Notification {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  ruleId    String?
  createdAt DateTime  @default(now())
  readAt    DateTime?

  @@index([userId, createdAt])
  @@map("notifications")
}

enum InsightPeriod {
  DAILY
  WEEKLY
}

model Insight {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  period      InsightPeriod
  /// e.g. "sleepScore", "recoveryScore", "automationEffectiveness"
  metric      String
  periodStart DateTime
  periodEnd   DateTime
  value       Float
  /// Signed delta vs. the prior comparable period
  trend       Float?
  summary     String?
  createdAt   DateTime      @default(now())

  @@index([userId, period, periodStart])
  @@map("insights")
}

enum RecommendationStatus {
  PENDING
  ACCEPTED
  DISMISSED
  EXPIRED
}

model Recommendation {
  id               String               @id @default(uuid())
  userId           String
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  title            String
  description      String
  /// AutomationAction[] this recommendation would create if accepted
  suggestedActions Json
  status           RecommendationStatus @default(PENDING)
  createdAt        DateTime             @default(now())
  respondedAt      DateTime?

  @@index([userId, status])
  @@map("recommendations")
}

model UserPreferences {
  userId                 String    @id
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  quietHoursStart        String?
  quietHoursEnd          String?
  notificationsEnabled   Boolean   @default(true)
  automationsEnabled     Boolean   @default(true)
  /// Manual override: when set and in the future, dispatch skips every
  /// rule with SKIPPED_MANUAL_PAUSE rather than checking conditions at
  /// all — the dashboard's "Pause automations for 1 hour" control. Unlike
  /// `automationsEnabled` (a standing preference), this is a temporary,
  /// self-expiring override — see docs/DECISION_ENGINE_ARCHITECTURE.md.
  automationsPausedUntil DateTime?
  preferredUnits         String    @default("imperial")
  updatedAt              DateTime  @updatedAt

  @@map("user_preferences")
}
