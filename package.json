{
  "name": "moodsync-platform",
  "private": true,
  "version": "0.1.0",
  "description": "MoodSync: the intelligence layer between wearable health data and smart home platforms.",
  "workspaces": [
    "frontend",
    "backend",
    "shared",
    "database",
    "ai",
    "workers",
    "integrations/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@11.16.0",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "db:generate": "npm run db:generate -w database",
    "db:migrate": "npm run db:migrate -w database"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
