# Copy to .env and fill in real values. Never commit the real .env file
# (it's gitignored) — see docs/MILESTONES.md for which of these are needed
# by which milestone.

# --- Database -----------------------------------------------------------
DATABASE_URL="postgresql://moodsync:moodsync@localhost:5432/moodsync_dev"

# --- Auth (Milestone 1) --------------------------------------------------
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
JWT_ACCESS_TOKEN_TTL="15m"
JWT_REFRESH_TOKEN_TTL="30d"

# AES-256-GCM key for encrypting third-party OAuth tokens at rest.
# Generate with: openssl rand -base64 32
OAUTH_TOKEN_ENCRYPTION_KEY=""

# --- WHOOP (Milestone 2) -------------------------------------------------
# Register at https://developer.whoop.com — see docs/INTEGRATIONS_RESEARCH.md
WHOOP_CLIENT_ID=""
WHOOP_CLIENT_SECRET=""
WHOOP_REDIRECT_URI="http://localhost:3000/api/integrations/whoop/callback"

# --- Philips Hue (Milestone 3) -------------------------------------------
# Register at https://developers.meethue.com
HUE_CLIENT_ID=""
HUE_CLIENT_SECRET=""
HUE_REDIRECT_URI="http://localhost:3000/api/integrations/hue/callback"

# --- Google Health API (Milestone 5 — gated on CASA assessment for prod) -
# Register a project at https://console.cloud.google.com
GOOGLE_HEALTH_CLIENT_ID=""
GOOGLE_HEALTH_CLIENT_SECRET=""
GOOGLE_HEALTH_REDIRECT_URI="http://localhost:3000/api/integrations/google-health/callback"

# --- Spotify (Milestone 6 — gated on Extended Quota Mode approval) ------
# Register at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
SPOTIFY_REDIRECT_URI="http://localhost:3000/api/integrations/spotify/callback"

# --- Server ---------------------------------------------------------------
PORT="3000"
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3001"
