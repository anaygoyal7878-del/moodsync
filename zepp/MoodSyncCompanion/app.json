{
  "configVersion": "v2",
  "app": {
    "appId": 1000001,
    "appName": "MoodSync",
    "appType": "app",
    "version": {
      "code": 1,
      "name": "1.0.0"
    },
    "icon": "assets/icon.png",
    "vender": "MoodSync",
    "description": "Syncs heart rate, sleep, and steps from your Amazfit watch to MoodSync."
  },
  "permissions": [
    "data:user.hd.sleep",
    "data:user.hd.step",
    "data:os.device.info"
  ],
  "runtime": {
    "apiVersion": {
      "compatible": 3,
      "target": 3,
      "minVersion": "3.0.0"
    }
  },
  "targets": {
    "gtr4": {
      "module": {
        "page": {
          "pages": ["page/index"]
        },
        "app-side": {
          "path": "app-side/index"
        },
        "setting": {
          "path": "setting/index"
        }
      },
      "platforms": [
        {
          "name": "gtr4",
          "deviceSource": 32
        }
      ],
      "designWidth": 454
    },
    "gts4": {
      "module": {
        "page": {
          "pages": ["page/index"]
        },
        "app-side": {
          "path": "app-side/index"
        },
        "setting": {
          "path": "setting/index"
        }
      },
      "platforms": [
        {
          "name": "gts4",
          "deviceSource": 33
        }
      ],
      "designWidth": 390
    },
    "balance": {
      "module": {
        "page": {
          "pages": ["page/index"]
        },
        "app-side": {
          "path": "app-side/index"
        },
        "setting": {
          "path": "setting/index"
        }
      },
      "platforms": [
        {
          "name": "balance",
          "deviceSource": 39
        }
      ],
      "designWidth": 480
    }
  },
  "i18n": {
    "en-US": {
      "appName": "MoodSync"
    }
  },
  "defaultLanguage": "en-US"
}
